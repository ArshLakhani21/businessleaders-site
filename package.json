{
  "name": "businessleaders-site",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Astro static site for businessleaders.in. Auto-published by businessleaders-engine via git push.",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "packageManager": "pnpm@11.0.3",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/rss": "4.0.9",
    "@astrojs/sitemap": "3.2.1",
    "@astrojs/tailwind": "5.1.2",
    "astro": "4.16.10",
    "tailwindcss": "^3.4.14"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "allowBuilds": {
      "esbuild": true,
      "sharp": true
    }
  }
}
