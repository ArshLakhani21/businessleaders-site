---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact">
  <article class="article-prose max-w-prose">
    <h1 class="font-serif text-3xl font-bold mb-6">Contact</h1>

    <p>
      For tips, corrections, partnerships, or feedback, write to:{' '}
      <a href="mailto:connect@publicmediasolution.com">connect@publicmediasolution.com</a>.
    </p>

    <h2>Corrections</h2>
    <p>
      If you spot a factual error, please email us with the URL of the article and a brief note
      on what is wrong. Confirmed corrections appear at the bottom of the affected piece.
    </p>
  </article>
</BaseLayout>
