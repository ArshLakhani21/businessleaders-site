---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found">
  <div class="text-center py-20">
    <p class="text-sm uppercase tracking-wide text-accent mb-2">404</p>
    <h1 class="font-serif text-4xl font-bold mb-3">Page not found</h1>
    <p class="text-muted mb-6">
      The article you are looking for is not here. It may have been moved or never existed.
    </p>
    <a href="/" class="inline-block border border-rule px-4 py-2 rounded text-sm">
      Back to homepage
    </a>
  </div>
</BaseLayout>
