---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const BEATS = {
  business: 'Business',
  finance: 'Finance',
  entertainment: 'Entertainment',
  lifestyle: 'Lifestyle',
  health: 'Health and Fitness',
  travel: 'Travel',
  international: 'International',
  sports: 'Sports',
  astro: 'Astrology',
} as const;

export async function getStaticPaths() {
  return Object.keys({
    business: 1,
    finance: 1,
    entertainment: 1,
    lifestyle: 1,
    health: 1,
    travel: 1,
    international: 1,
    sports: 1,
    astro: 1,
  }).map((beat) => ({ params: { beat } }));
}

const { beat } = Astro.params;
const beatName = BEATS[beat as keyof typeof BEATS] ?? beat;

const all = await getCollection('articles');
const items = all
  .filter((entry) => entry.data.beat === beat)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<BaseLayout
  title={`${beatName} — Business Leaders India`}
  description={`Latest ${beatName.toLowerCase()} news from Business Leaders India.`}
>
  <h1 class="font-serif text-3xl font-bold mb-6">{beatName}</h1>

  {items.length === 0 ? (
    <div class="text-muted py-8">No articles published in this beat yet.</div>
  ) : (
    items.map((entry) => (
      <ArticleCard
        title={entry.data.title}
        beat={entry.data.beat}
        slug={entry.slug}
        metaDescription={entry.data.metaDescription}
        imagePath={entry.data.image.path}
        imageAlt={entry.data.image.alt}
        publishedAt={entry.data.publishedAt}
        authorName={entry.data.author.name}
      />
    ))
  )}
</BaseLayout>
