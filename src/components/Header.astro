---
import { BEATS } from '../data/beats.ts';

interface Props {
  activeBeat?: string;
}

const { activeBeat } = Astro.props;
---

<nav class="sticky top-0 z-50 bg-white shadow-[0_1px_0_#e5e7eb]">
  <div class="flex items-center justify-between px-6 md:px-6 py-2.5 border-b border-rule-soft">
    <a href="/" class="font-serif text-[1.55rem] font-extrabold leading-none cursor-pointer select-none">
      <span class="text-navy">Business</span><span class="text-gold ml-1">Leader</span>
    </a>

    <div class="flex items-center gap-3.5">
      <a
        href="/search/"
        class="p-1.5 rounded-md text-navy hover:text-gold transition-colors"
        aria-label="Search"
      >
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
      </a>
      <a
        href="#newsletter"
        class="bg-gold text-navy text-[0.78rem] font-bold uppercase tracking-[0.03em] px-[18px] py-[7px] rounded-full hover:bg-gold-deep hover:-translate-y-px transition whitespace-nowrap"
      >
        Subscribe
      </a>
      <button
        id="mobile-toggle"
        class="md:hidden p-1 text-navy"
        aria-label="Menu"
      >
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <div class="hidden md:block overflow-x-auto" style="scrollbar-width:none">
    <ul class="flex items-center px-6 list-none m-0 p-0">
      {BEATS.map((b) => (
        <li class="flex-shrink-0">
          <a href={`/${b.slug}/`} class:list={['nav-tab', 'block', activeBeat === b.slug && 'active']}>
            {b.navLabel}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div id="mobile-menu" class="md:hidden hidden bg-white border-t border-rule px-6 py-4">
    {BEATS.map((b) => (
      <a
        href={`/${b.slug}/`}
        class:list={[
          'block text-[0.9rem] font-semibold py-3 border-b border-rule-soft last:border-b-0 tracking-[0.02em]',
          activeBeat === b.slug ? 'text-gold' : 'text-ink',
        ]}
      >
        {b.navLabel}
      </a>
    ))}
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
