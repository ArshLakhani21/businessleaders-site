---
const beats = [
  { slug: 'business', name: 'Business' },
  { slug: 'finance', name: 'Finance' },
  { slug: 'entertainment', name: 'Entertainment' },
  { slug: 'sports', name: 'Sports' },
  { slug: 'lifestyle', name: 'Lifestyle' },
  { slug: 'health', name: 'Health' },
  { slug: 'travel', name: 'Travel' },
  { slug: 'international', name: 'International' },
  { slug: 'astro', name: 'Astrology' },
];
---

<header class="border-b border-rule">
  <div class="mx-auto max-w-6xl px-4 py-4 flex items-center justify-between">
    <a href="/" class="font-serif text-2xl font-bold text-ink hover:no-underline">
      Business Leaders India
    </a>
    <nav class="hidden md:flex gap-5 text-sm">
      {beats.map((b) => (
        <a href={`/${b.slug}/`} class="text-muted hover:text-ink hover:no-underline">
          {b.name}
        </a>
      ))}
    </nav>
  </div>
</header>
