---
import BeatBadge from './BeatBadge.astro';

interface Props {
  title: string;
  beat: string;
  slug: string;
  metaDescription?: string;
  imagePath: string;
  imageAlt: string;
  publishedAt: Date;
  authorName: string;
}

const { title, beat, slug, imagePath, imageAlt, publishedAt, authorName } = Astro.props;
const href = `/${beat}/${slug}/`;
const dateFormatted = publishedAt.toLocaleDateString('en-IN', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group cursor-pointer transition hover:-translate-y-0.5 hover:shadow-[0_8px_28px_rgba(13,27,42,0.1)]">
  <a href={href} class="block">
    <div class="w-full aspect-[16/9] overflow-hidden rounded mb-2.5 bg-rule-soft">
      <img
        src={imagePath}
        alt={imageAlt}
        loading="lazy"
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
      />
    </div>
    <div class="mb-1.5">
      <BeatBadge beat={beat} size="sm" link={false} />
    </div>
    <h3 class="card-headline mb-2 group-hover:text-gold transition-colors">{title}</h3>
    <div class="text-[0.72rem] text-muted flex items-center gap-1.5">
      <span>{authorName}</span>
      <span class="text-rule">·</span>
      <time datetime={publishedAt.toISOString()}>{dateFormatted}</time>
    </div>
  </a>
</article>
